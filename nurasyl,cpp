#include <iostream>
#include <vector>
#include <string>
#include <locale>
using namespace std;

struct Student {
    int id = 0;
    string name = "";
    int age = 0;
    double grade = 0.0;
};

int main() {
    setlocale(LC_ALL, "Russian");

    vector<Student> students;
    int n;

    cout << "Сколько студентов? ";
    cin >> n;

    for (int i = 0; i < n; i++) {
        Student s;
        s.id = i + 1;
        cout << "\nСтудент " << i + 1 << ":\n";
        cout << "Имя: ";     cin >> s.name;
        cout << "Возраст: "; cin >> s.age;
        cout << "Балл: ";    cin >> s.grade;
        students.push_back(s);
    }

    cout << "\nСписок студентов:\n";
    for (const auto& s : students) {
        cout << "ID: " << s.id
            << ", Имя: " << s.name
            << ", Возраст: " << s.age
            << ", Средний балл: " << s.grade
            << endl;
    }

    cout << "\n=== Тесты ===\n";

    if (students.size() > 0)
        cout << "[PASS] Студенты есть в базе\n";
    else
        cout << "[FAIL] База пустая!\n";

    bool ok = true;
    for (auto& s : students)
        if (s.grade < 1 || s.grade > 5) ok = false;

    if (ok)
        cout << "[PASS] Все баллы от 1 до 5\n";
    else
        cout << "[FAIL] Есть неверный балл!\n";

    return 0;
}
